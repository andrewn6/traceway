# Allowed browser origins for CORS (comma-separated).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://app.traceway.ai

# Optional: cookie domain for cross-subdomain auth cookies.
# SESSION_COOKIE_DOMAIN=.traceway.ai

# Defaults used by daemon->Encore trace bridge and workflow recovery cron.
# Set these to the org/project that daemon traffic should write into.
# TRACEWAY_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000000
# TRACEWAY_DEFAULT_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Service-to-service auth token (internal calls).
# If unset, local dev falls back to permissive auth mode in auth/auth.ts.
TRACEWAY_BACKEND_TOKEN=change-me

# Public app URL for billing redirects.
APP_URL=https://app.traceway.ai

# Polar billing integration
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PRO_ID=02a58cb6-1853-4179-ba29-6d65c71836db
POLAR_PRODUCT_TEAM_ID=507c5aeb-b4a2-47e4-870b-ea6b89814a9f

# Turbopuffer secondary search index (best-effort mirror)
TURBOPUFFER_API_KEY=
TURBOPUFFER_UPSERT_URL=
