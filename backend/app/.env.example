# Allowed browser origins for CORS (comma-separated).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://platform.traceway.ai

# Optional: cookie domain for cross-subdomain auth cookies.
# SESSION_COOKIE_DOMAIN=.traceway.ai

# Optional legacy defaults used only by stale eval recovery cron fallback.
# Daemon->Encore bridge now requires per-request x-traceway-org-id/project-id headers.
# TRACEWAY_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000000
# TRACEWAY_DEFAULT_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Service-to-service auth token (internal calls).
# If unset, local dev falls back to permissive auth mode in auth/auth.ts.
TRACEWAY_BACKEND_TOKEN=change-me

# Public app URL for billing redirects.
APP_URL=https://platform.traceway.ai

# Polar billing integration
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PRO_ID=
POLAR_PRODUCT_TEAM_ID=

# Optional transactional email (invites + password reset)
RESEND_API_KEY=
RESEND_FROM=

# Turbopuffer secondary search index (best-effort mirror via @turbopuffer/turbopuffer)
TURBOPUFFER_API_KEY=
# Namespace and region: https://turbopuffer.com/docs/regions
TURBOPUFFER_NAMESPACE=traceway
TURBOPUFFER_REGION=gcp-us-central1
# Optional overrides (seconds for timeout; URL must match your region if set)
# TURBOPUFFER_BASE_URL=
# TURBOPUFFER_TIMEOUT=30
