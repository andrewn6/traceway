# =============================================================================
# Traceway Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Port to bind the API server (default: 3000)
PORT=3000

# Path to SQLite database file (local mode)
DB_PATH=/data/traces.db

# -----------------------------------------------------------------------------
# Authentication (Cloud Mode)
# -----------------------------------------------------------------------------

# Enable cloud mode (enables auth, multi-tenancy)
TRACEWAY_CLOUD=true

# JWT secret for session tokens (required in cloud mode)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Pre-configured API keys (comma-separated, format: name:key or just key)
# These are hashed on startup, so use the actual key value
TRACEWAY_API_KEYS=

# Single API key (alternative to TRACEWAY_API_KEYS)
TRACEWAY_API_KEY=

# Postgres connection URL for user/auth data (required in cloud mode)
DATABASE_URL=postgres://user:pass@host:5432/traceway

# -----------------------------------------------------------------------------
# Storage Backend (Cloud Mode)
# -----------------------------------------------------------------------------

# Which storage backend to use for trace data: "sqlite" or "turbopuffer"
STORAGE_BACKEND=turbopuffer

# Turbopuffer API key (required when STORAGE_BACKEND=turbopuffer)
TURBOPUFFER_API_KEY=

# Turbopuffer namespace prefix (default: traceway)
TURBOPUFFER_NAMESPACE=traceway

# Turbopuffer regional endpoint (default: https://gcp-us-central1.turbopuffer.com)
TURBOPUFFER_BASE_URL=https://gcp-us-central1.turbopuffer.com

# Turbopuffer request timeout in seconds (default: 30)
TURBOPUFFER_TIMEOUT=30

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------

# Resend API key for sending invite and password reset emails
RESEND_API_KEY=

# From address for emails (default: Traceway <noreply@traceway.dev>)
RESEND_FROM=Traceway <noreply@traceway.dev>

# Base URL for links in emails (e.g. invite accept, password reset)
APP_URL=https://app.traceway.dev

# -----------------------------------------------------------------------------
# Billing (Polar.sh)
# -----------------------------------------------------------------------------

# Polar webhook secret for verifying subscription events (Standard Webhooks format)
# Get this from your Polar dashboard: Organization Settings > Webhooks > Secret
POLAR_WEBHOOK_SECRET=

# Polar organization access token for creating checkout sessions
# Get this from your Polar dashboard: Organization Settings > Access Tokens
POLAR_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Redis (Event Bus for Multi-Instance)
# -----------------------------------------------------------------------------

# Redis URL for distributed event bus (optional, enables real-time sync across instances)
# Format: redis://user:password@host:port/db
REDIS_URL=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# Log level: trace, debug, info, warn, error (default: info)
TRACEWAY_LOG=info

# Log format: "json" or "pretty" (default: json in cloud mode)
LOG_FORMAT=json

# Enable Prometheus metrics endpoint at /api/metrics (default: true)
METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Frontend (UI)
# -----------------------------------------------------------------------------

# API URL for the frontend (only needed when deploying UI separately)
# Set this in Vercel/Cloudflare Pages environment variables
VITE_API_URL=https://your-api-server.railway.app/api

# -----------------------------------------------------------------------------
# Platform-Specific (Auto-detected)
# -----------------------------------------------------------------------------

# These are typically set automatically by your cloud platform:
#
# Fly.io:
#   FLY_REGION, FLY_ALLOC_ID
#
# Railway:
#   RAILWAY_REGION, RAILWAY_REPLICA_ID
#
# AWS:
#   AWS_REGION
#
# Generic:
#   REGION, HOSTNAME
